{
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/reset-password", "destination": "/reset-password.html" },
    { "source": "/buyer-portal", "destination": "/buyer-portal.html" },
    { "source": "/manufacturer-portal", "destination": "/manufacturer-portal.html" },
    { "source": "/buyers-club", "destination": "/buyers-club.html" },
    { "source": "/manufacturers-club", "destination": "/manufacturers-club.html" },
    { "source": "/the-opportunity", "destination": "/the-opportunity.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/product-analyser", "destination": "/product-analyser.html" }
  ]
}
