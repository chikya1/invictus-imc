{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/the-opportunity",
      "dest": "/the-opportunity.html"
    },
    {
      "src": "/manufacturers-club",
      "dest": "/manufacturers-club.html"
    },
    {
      "src": "/buyers-club",
      "dest": "/buyers-club.html"
    },
    {
      "src": "/admin",
      "dest": "/admin.html"
    }
  ]
}
